# Content Machine — environment template
# Copy to .env and fill in YOUR OWN values. Never commit .env.
# Every value below is a placeholder. No real keys or IDs ship in this repo.

# --- Core generation + grading ---
ANTHROPIC_API_KEY=your-anthropic-api-key

# --- Trend scout data sources ---
YOUTUBE_DATA_API_KEY=your-youtube-data-api-key
RAPIDAPI_KEY=your-rapidapi-key            # Reddit / IG / LinkedIn miners

# --- Publishing (only fires on your explicit approval) ---
SCHEDULER_API_KEY=your-social-scheduler-api-key

# --- Video production ---
AVATAR_API_KEY=your-avatar-engine-api-key
TTS_API_KEY=your-text-to-speech-api-key

# --- Google (Sheets calendar + mail), via Application Default Credentials ---
GOOGLE_APPLICATION_CREDENTIALS=application_default
GOOGLE_SHEETS_ID=your-google-sheet-id
MAIL_SENDER=you@example.com

# --- Optional attribution sources (each activates independently) ---
# STRIPE_API_KEY=restricted-read-only-key
# EMAIL_PLATFORM_API_KEY=your-email-platform-key
